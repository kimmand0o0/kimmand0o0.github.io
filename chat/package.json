{
  "name": "kimmand0o0-blog-chat",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build-embeddings": "node scripts/build-embeddings.mjs",
